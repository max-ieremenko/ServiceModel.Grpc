<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Microsoft.SourceLink.GitHub</id>
    <version>10.0.201</version>
    <authors>Microsoft</authors>
    <developmentDependency>true</developmentDependency>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>Icon.png</icon>
    <projectUrl>https://github.com/dotnet/dotnet</projectUrl>
    <description>Generates source link for GitHub repositories.</description>
    <copyright>© Microsoft Corporation. All rights reserved.</copyright>
    <tags>MSBuild Tasks GitHub source link</tags>
    <serviceable>true</serviceable>
    <repository type="git" url="https://github.com/dotnet/dotnet" commit="4d3023de605a78ba3e59e50c657eed70f125c68a" />
    <dependencies>
      <group targetFramework=".NETFramework4.7.2">
        <dependency id="Microsoft.Build.Tasks.Git" version="10.0.201" exclude="Build,Analyzers" />
        <dependency id="Microsoft.SourceLink.Common" version="10.0.201" exclude="Build,Analyzers" />
        <dependency id="System.IO.Hashing" version="10.0.5" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net8.0">
        <dependency id="Microsoft.Build.Tasks.Git" version="10.0.201" exclude="Build,Analyzers" />
        <dependency id="Microsoft.SourceLink.Common" version="10.0.201" exclude="Build,Analyzers" />
        <dependency id="System.IO.Hashing" version="10.0.5" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>